APP_NAME=Tea Shop VK Bot Backend
DEBUG=True

# VK Callback API (Управление сообществом -> Работа с API -> Callback API)
VK_CONFIRMATION_TOKEN=
VK_SECRET_KEY=
VK_GROUP_ID=
# VK Callback API (Управление сообществом -> Работа с API -> Ключи доступа)
VK_ACCESS_TOKEN=
VK_API_VERSION=5.199

# Claude (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# CDEK API (личный кабинет CDEK -> Интеграция -> API ключи)
# Тестовый контур по умолчанию: https://api.edu.cdek.ru
CDEK_API_BASE_URL=https://api.edu.cdek.ru
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
CDEK_FROM_ADDRESS=
CDEK_DEFAULT_PACKAGE_WEIGHT_GRAMS=200

# Telegram-бот для уведомлений менеджера (создать через @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_ID=
